---
import { siGithub, siGoodreads, siLetterboxd } from 'simple-icons';
import { SITE_TITLE } from '../consts';
import Squiggle from './Squiggle.astro';

const today = new Date();

const linkedinPath = 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z';

const socials = [
	{ path: siGithub.path, href: 'https://github.com/yourusername', label: 'GitHub' },
	{ path: linkedinPath, href: 'https://linkedin.com/in/yourusername', label: 'LinkedIn' },
	{ path: siGoodreads.path, href: 'https://goodreads.com/yourusername', label: 'Goodreads' },
	{ path: siLetterboxd.path, href: null, label: 'Letterboxd' },
];
---

<footer>
	<div class="squiggle-wrapper"><Squiggle /></div>
	<p class="links-label">You can find me here as well:</p>
	<div class="social-links">
		{socials.map(({ path, href, label }) =>
			href ? (
				<a href={href} target="_blank" rel="noopener noreferrer">
					<svg role="img" viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
						<path d={path} />
					</svg>
					<span class="social-label">{label}</span>
				</a>
			) : (
				<span class="disabled">
					<svg role="img" viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
						<path d={path} />
					</svg>
					<span class="social-label">{label}</span>
				</span>
			)
		)}
	</div>
	<p class="copyright">&copy; {today.getFullYear()} Øyvind Harding Gulbrandsen</p>
</footer>
<style>
	footer {
		padding: 0 1em 3em;
		text-align: center;
	}
	.squiggle-wrapper {
		margin-bottom: 2.5rem;
	}
	.links-label {
		margin: 0 0 2rem;
		color: rgb(var(--gray));
		font-size: 0.8rem;
		letter-spacing: 0.1em;
	}
	.social-links {
		display: flex;
		justify-content: center;
		gap: 1.25rem;
		margin-bottom: 2rem;
	}
	.social-links a,
	.social-links .disabled {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.35rem;
	}
	.social-links a {
		color: rgb(var(--gray));
		text-decoration: none;
		transition: color 0.2s ease;
	}
	.social-links a:hover {
		color: rgb(var(--black));
	}
	.disabled {
		color: rgb(var(--gray-light));
		cursor: default;
	}
	.social-label {
		font-size: 0.7rem;
	}
	.copyright {
		margin: 0;
		color: rgb(var(--gray));
		font-size: 0.85rem;
	}
</style>
