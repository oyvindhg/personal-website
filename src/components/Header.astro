---
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2>
			<HeaderLink href="/">Home</HeaderLink>
		</h2>
		<div class="internal-links">
			<HeaderLink href="/things">Things</HeaderLink>
			<HeaderLink href="/now">Now</HeaderLink>
			<HeaderLink href="/notes">Notes</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: var(--bg);
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}

	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}

	.internal-links {
		display: flex;
		gap: 1rem;
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 720px;
		width: 100%;
		margin: 0 auto;
	}

	nav a {
		padding: 1em 0 0.4em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}

	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
</style>
